# Kapture Logistics — Environment Variables
# Copy this file to .env.local and fill in real values before running.

# ── Supabase (Lead capture, contact, quote requests) ────────────────────────
# Create a free project at https://supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Kapture lead routing ────────────────────────────────────────────────────
# Every form submission emails this address with all lead details.
KAPTURE_LEAD_NOTIFY_EMAIL=studio@thekapture.com

# Optional Make.com / Zapier webhook (fan-out to Notion, Klaviyo, etc.)
KAPTURE_LEAD_WEBHOOK_URL=

# ── Resend (email delivery for lead notifications) ─────────────────────────
# Free 3,000 emails/month. Sign up at https://resend.com → API Keys → Create.
# The default `onboarding@resend.dev` sender works without domain verification.
# Once thekapture.com is verified in Resend, swap RESEND_FROM_EMAIL for a
# branded sender like "Kapture Logistics <leads@thekapture.com>".
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=Kapture Logistics <onboarding@resend.dev>

# ── Calendly (discovery call booking after every form submission) ──────────
# Create a 15-minute event type at calendly.com and paste the public URL here.
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/kapture/discovery

# ── Site config ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://kapture-logistics.vercel.app
NEXT_PUBLIC_BRAND_NAME=Kapture Logistics
NEXT_PUBLIC_PARENT_BRAND_NAME=Kapture
NEXT_PUBLIC_PARENT_BRAND_URL=https://thekapture.com
